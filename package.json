{
  "name": "react-use-echarts",
  "private": false,
  "version": "1.0.5",
  "description": "A powerful React hooks library for Apache ECharts",
  "keywords": [
    "react",
    "hooks",
    "echarts",
    "charts",
    "data-visualization",
    "typescript",
    "themes",
    "lazy-loading",
    "chart-linkage",
    "resize-observer"
  ],
  "type": "module",
  "author": "Ethan",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chensid/react-use-echarts.git"
  },
  "homepage": "https://github.com/chensid/react-use-echarts#readme",
  "bugs": {
    "url": "https://github.com/chensid/react-use-echarts/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "default": "./dist/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "test": "vp test",
    "coverage": "vp test run --coverage",
    "lint": "vp lint .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc -b",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "echarts": "^6.0.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-dts": "^4.5.4",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "peerDependencies": {
    "echarts": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
